{
  "$schema": "https://opencode.ai/config.json",
  "share": "manual",
  "autoupdate": "notify",
  "instructions": ["AGENTS.md", "README.md", "docs/live-project.md"],
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git status": "allow",
      "git diff": "allow",
      "npm run build": "allow",
      "npm test": "allow"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": false
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": false
    }
  }
}
